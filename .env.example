# Ethereal Trade - Töltsd ki Railway-en (Variables fül)
PRIVATE_KEY=your_wallet_private_key_here
SUBACCOUNT=primary
PRODUCT=BTCUSD

# Kereskedési paraméterek (DCA-Martingale)
BASE_ORDER_USD=10
MAX_SAFETY_LEVELS_LONG=2
MAX_SAFETY_LEVELS_SHORT=3
VIRTUAL_CAPITAL=350
ACCOUNT_NAME=Railway_Bot

# Bollinger Bands & RSI
BB_PERIOD=20
BB_STD=2.0
BB_CANDLE_INTERVAL=15m
RSI_PERIOD=14

# Bot működés
POLL_INTERVAL_SEC=60
DRY_RUN=true

# Telegram (kötelező a vezérléshez)
TELEGRAM_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
